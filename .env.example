# =============================================
# ПИС «Маршрут» — пример переменных окружения
# Скопируйте этот файл в .env и заполните секреты
# =============================================

# ---------- Postgres ----------
POSTGRES_DB=pis_marshrut
POSTGRES_USER=pis_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# DSN, используемый бэкендом (SQLAlchemy)
DATABASE_URL=postgresql+psycopg2://pis_user:change_me_strong_password@db:5432/pis_marshrut

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0

# ---------- Backend (FastAPI) ----------
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# JWT
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---------- Внешняя ВИС ----------
VIS_BASE_URL=https://vis.example.local/api
VIS_API_KEY=

# ---------- OSRM (маршрутизация по реальным дорогам OSM) ----------
# Публичный демо-сервер OSRM подходит для разработки.
# Для production поднимите свой: https://github.com/Project-OSRM/osrm-backend
OSRM_BASE_URL=https://router.project-osrm.org

# ---------- Overpass API (импорт остановок из OSM) ----------
OVERPASS_URL=https://overpass-api.de/api/interpreter

# ---------- Frontend (Next.js) ----------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
NEXT_PUBLIC_MAP_ATTRIBUTION=© OpenStreetMap contributors
NEXT_PUBLIC_DEFAULT_CENTER_LAT=51.7682
NEXT_PUBLIC_DEFAULT_CENTER_LON=55.0972
NEXT_PUBLIC_DEFAULT_ZOOM=12
